# Dependencies
node_modules
.npm

# Angular cache
.angular

# Git and IDE
.git
.gitignore
.cursor
.vscode
.idea
*.swp
*.swo

# Logs and temp
*.log
npm-debug.log*
tmp
temp

# Test and coverage
coverage
.nyc_output
e2e

# Env (secrets)
.env
.env.*
server/.env

# Docker
.dockerignore

# Notes:
# - We DO NOT ignore dist/ because the EC2 prebuilt flow needs it (Dockerfile.prebuilt).
# - If you only ever build inside Docker (Dockerfile), you can add dist/ back to speed up contexts.
