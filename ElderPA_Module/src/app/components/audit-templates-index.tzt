import { AuditTemplate } from './Types';

/**
 * COMPLETE AUDIT TEMPLATES COLLECTION
 * Combines all three audit categories used in care home compliance audits
 */
export const ALL_AUDIT_TEMPLATES: AuditTemplate[] = [
  ...BASELINE_AUDIT_TEMPLATES,
  ...REGISTERED_MANAGER_AUDIT_TEMPLATES,
  ...PROVIDER_AUDIT_TEMPLATES,
];

/**
 * Organized audit templates by category
 */
export const AUDIT_TEMPLATES_BY_CATEGORY = {
  baseline: BASELINE_AUDIT_TEMPLATES,
  registeredManager: REGISTERED_MANAGER_AUDIT_TEMPLATES,
  provider: PROVIDER_AUDIT_TEMPLATES,
};

