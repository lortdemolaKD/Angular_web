/**
 * Get templates by specific criteria
 */
export function getAuditTemplatesByType(type: 'baseline' | 'registeredManager' | 'provider'): AuditTemplate[] {
  return AUDIT_TEMPLATES_BY_CATEGORY[type];
}

export function getAuditTemplateById(id: string): AuditTemplate | undefined {
  return ALL_AUDIT_TEMPLATES.find((template) => template._id === id);
}

export function getAuditTemplatesByResponsibility(role: string): AuditTemplate[] {
  return ALL_AUDIT_TEMPLATES.filter((template) =>
    template.responsibleRoles?.includes(role)
  );
}

export function getAuditTemplatesByFrequency(frequency: string): AuditTemplate[] {
  return ALL_AUDIT_TEMPLATES.filter(
    (template) => template.frequency?.toLowerCase() === frequency.toLowerCase()
  );
}

/**
 * AUDIT STATISTICS
 */
export const AUDIT_STATISTICS = {
  totalTemplates: ALL_AUDIT_TEMPLATES.length,
  baselineCount: BASELINE_AUDIT_TEMPLATES.length,
  registeredManagerCount: REGISTERED_MANAGER_AUDIT_TEMPLATES.length,
  providerCount: PROVIDER_AUDIT_TEMPLATES.length,
  totalQuestions: ALL_AUDIT_TEMPLATES.reduce(
    (sum, template) =>
      sum +
      (template.sections?.reduce(
        (sectionSum, section) => sectionSum + (section.questions?.length || 0),
        0
      ) || 0),
    0
  ),
};

