# Prebuilt app image (no Angular build).
# Requires: dist/ is present (built on your PC via `npm run build`).

FROM node:20-alpine AS runner

WORKDIR /app

COPY package.json package-lock.json* ./
# Use npm install (not npm ci) so lockfile parity isn't required on the server.
RUN npm install --omit=dev

COPY dist ./dist

ENV NODE_ENV=production
EXPOSE 4000

CMD ["node", "dist/ElderPA_Module/server/server.mjs"]

